    "google_adsense": {
      "strategies": [
        {
          "name": "single_high_viewability_unit",
          "description": "One conservative, high-visibility ad unit per page with no refresh.",
          "inputs": {
            "pageviews": "Number of pageviews."
          },
          "parameters": {
            "ad_slots_per_page": {
              "value": 1,
              "source": "None",
              "confidence": "high"
            },
            "fill_rate": {
              "value": 0.75,
              "source": "None",
              "confidence": "low"
            },
            "viewability_rate": {
              "value": 0.5,
              "source": "https://www.iab.com/guidelines/viewability/",
              "confidence": "medium"
            },
            "cpm": {
              "value": 0.5,
              "source": "https://www.monetizemore.com/blog/adsense-cpm-rates/",
              "confidence": "medium"
            },
            "policy_compliance_factor": {
              "value": 1.0,
              "source": "None",
              "confidence": "low"
            }
          },
          "formula": "estimated_revenue = pageviews * ad_slots_per_page * fill_rate * viewability_rate * cpm / 1000 * policy_compliance_factor"
        }
      ]
    },

